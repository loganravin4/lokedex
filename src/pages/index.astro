---
import BaseLayout from '../layouts/BaseLayout.astro';
import PokedexCard from '../components/projects/PokedexCard';
import TypeBadge from '../components/projects/TypeBadge';
import TypingTitle from '../components/features/TypingTitle';
import SpotifyWidget from '../components/features/SpotifyWidget';
import AnalyticsTracker from '../components/analytics/AnalyticsTracker';
import { fetchFeaturedProjects } from '../lib/fetchProjects';

// Fetch featured projects from Sanity
const projects = await fetchFeaturedProjects();

// Transform Sanity data to match component props
const transformedProjects = projects.map((project) => ({
  id: project._id,
  name: project.name,
  description: project.description,
  shortDescription: project.shortDescription,
  types: project.types,
  techs: project.techs,
  link: project.link,
  github: project.github,
}));

const techStack = [
  { type: 'electric', tech: 'TypeScript' },
  { type: 'water', tech: 'React' },
  { type: 'fire', tech: 'Node.js' },
  { type: 'grass', tech: 'Python' },
  { type: 'psychic', tech: 'SQL' },
  { type: 'dragon', tech: 'Java' },
  { type: 'steel', tech: 'C/C++' },
  { type: 'ghost', tech: 'AWS' },
  { type: 'fairy', tech: 'Docker' },
  { type: 'ice', tech: 'Astro' },
  { type: 'fighting', tech: 'Git' },
  { type: 'rock', tech: 'Linux' },
];
---

<BaseLayout title="Logan's Lokédex - Gotta Code 'Em All!">
  <AnalyticsTracker pageName="Home" client:load />
  <main class="container mx-auto px-4 py-8 max-w-7xl">
    <!-- Hero Section -->
    <section class="min-h-[75vh] flex items-center justify-center mb-8">
      <div class="text-center">
        <!-- Headshot -->
        <div class="mb-8 flex justify-center">
          <div class="relative">
            <img
              src="/headshot.png"
              alt="Logan Ravinuthala"
              class="w-48 h-48 md:w-64 md:h-64 rounded-full border-4 border-poke-yellow shadow-2xl object-cover hover:scale-105 transition-transform duration-300"
              onerror="this.src = '/favicon.svg'; this.onerror = null;"
            />
            <div class="absolute -bottom-2 -right-2 bg-poke-yellow text-poke-black px-3 py-1 rounded-full font-pokemon text-xs border-2 border-poke-black">
              Lv. 100
            </div>
          </div>
        </div>
        
        <h1 class="font-pokemon text-4xl md:text-6xl text-poke-yellow mb-6 animate-pulse-slow">
          LOGAN'S
          <br />
          <span class="text-poke-red">LOKÉDEX</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 mb-2 font-mono min-h-[2rem]">
          <TypingTitle
            titles={[
              'Full-Stack Developer',
              'Backend Engineer',
              'Software Engineer',
              'Technical Lead',
              'Embedded Software Engineer',
              'Machine Learning Engineer',
              'Data Engineer',
              'Pokémon Trainer',
              'Mario Kart Speedrunner',
              'The Weeknd\'s Biggest Fan',
              'Gym Rat',
              'Cheese Pizza Lover',
              'Technical Problem Solver',
              'GOAT',
              'Karaoke Machine',
              'Project-Based Learner',
              'Nintendo Fanatic',
              'Your Next Partner',
            ]}
            baseText=""
            typingSpeed={100}
            deletingSpeed={50}
            pauseDuration={2000}
            client:load
          />
        </p>
        <p class="text-lg text-white/70 mb-4 font-mono">
          Honors Computer Engineering & Computer Science @ Northeastern University
        </p>
        <p class="text-sm md:text-base text-white/75 mb-8 max-w-2xl mx-auto font-mono leading-relaxed px-2">
          Exploring New Grad software engineering (or related) opportunities for when I graduate in {' '}
          <span data-graduation-countdown class="font-semibold text-poke-yellow">…</span>
          {' '}(<span data-graduation-days class="font-semibold text-poke-yellow">--</span>
          {' '}days).
          <a href="#new-grad" class="text-poke-blue hover:text-poke-blue/90 underline underline-offset-2 ml-1 whitespace-nowrap">Full timeline</a>
        </p>
        <div class="flex flex-wrap justify-center gap-4 mb-8">
          <a
            href="#projects"
            class="bg-poke-red hover:bg-poke-red/80 transition-colors px-8 py-4 rounded-lg font-bold text-white text-lg border-4 border-white/20"
            data-track-cta="View Favorites"
          >
            View Favorites
          </a>
          
          <a
            href="#about"
            class="bg-poke-blue hover:bg-poke-blue/80 transition-colors px-8 py-4 rounded-lg font-bold text-white text-lg border-4 border-white/20"
            data-track-cta="About Trainer"
          >
            About Trainer
          </a>
        </div>
      </div>
    </section>

    <!-- Welcome Message -->
    <section class="mb-8 max-w-3xl mx-auto">
      <div class="bg-gradient-to-r from-poke-yellow/20 to-poke-red/20 rounded-2xl p-6 md:p-8 border-4 border-poke-yellow/40 text-center">
        <p class="text-white/90 text-lg md:text-xl leading-relaxed">
          Welcome to the <span class="font-pokemon text-poke-yellow">LOKÉDEX</span>! 
          Get it? My name is <span class="font-bold text-poke-yellow">Logan</span>, I love <span class="font-bold text-poke-yellow">Pokémon</span>, and this is my take on the 
          <span class="font-bold text-poke-red">Pokédex</span>: a collection of projects, experiences, and skills I've caught and trained. 
          Gotta code 'em all! 🎮
        </p>
      </div>
    </section>

    <!-- Tech Stack Section -->
    <section id="skills" class="mb-20" data-section="skills">
      <h2 class="font-pokemon text-3xl text-poke-yellow mb-8 text-center">
        TYPE EFFECTIVENESS
      </h2>
      <p class="text-center text-white/70 mb-8">
        Technologies I've caught and trained
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        {techStack.map((item) => (
          <TypeBadge type={item.type} tech={item.tech} client:load />
        ))}
      </div>
    </section>

    <!-- Projects Section (Lokédex) -->
    <section id="projects" class="mb-20" data-section="projects">
      <div class="text-center mb-12">
        <h2 class="font-pokemon text-3xl text-poke-yellow mb-4">
          PROJECT LOKÉDEX
        </h2>
        <p class="text-white/80">
          The Elite Four of my Portfolio
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {transformedProjects.map((project, index) => (
          <PokedexCard project={project} index={index} client:load />
        ))}
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="mb-20 bg-gradient-to-r from-poke-blue/20 to-poke-psychic/20 rounded-2xl p-8 border-4 border-poke-yellow/30" data-section="about">
      <h2 class="font-pokemon text-3xl text-poke-yellow mb-6">
        ABOUT THE TRAINER
      </h2>
      <div class="space-y-4 text-white/90">
        <p>
          Hey! I'm Logan, an Honors Computer Engineering and Computer Science student at Northeastern University.
        </p>
        <p>
          I'm an incoming Software Engineer Co-op at MORSE Corp, where I'll be contributing to best-in-class technical solutions for difficult multidisciplinary problems in the U.S. national security ecosystem.
        </p>
        <p>
          I've previously worked as a Software Engineer at NExT Consulting, both as a co-op and part-time.
          I contributed to building innovative software solutions for external clients, including an AI Chief-of-Staff and a data analytics platform.
        </p>
        <p>
          On campus, I serve as a Software Engineer at Generate Product Development Studio, a Teaching Assistant for Introduction to Databases (CS3200), 
          and a Project Lead at both the Student Government Association and Artificial Intelligence Northeastern.
        </p>
        <p>
          When I'm not coding, you'll find me weightlifting, going on long walks with no destination, gaming on Mario Kart or Pokémon, or vibing with my 76,533 minutes on Spotify (will almost ALWAYS be The Weeknd).
        </p>
      </div>

      <!-- Spotify Widget -->
      <div class="mt-8">
        <SpotifyWidget client:load />
      </div>
      
      <!-- Education -->
      <div class="mt-8 pt-8 border-t-2 border-white/10">
        <h3 class="font-pokemon text-xl text-poke-yellow mb-4">EDUCATION</h3>
        <div class="space-y-3 text-white/90">
          <div>
            <div class="font-bold text-white">Northeastern University</div>
            <div class="text-sm text-white/70">BSCmpE Computer Engineering & Computer Science (Honors)</div>
            <div class="text-sm text-white/60">GPA: 3.96/4.0</div>
          </div>
        </div>
      </div>
      
      <!-- Social Links -->
      <div class="flex flex-wrap gap-4 mt-8">
        <a
          href="https://github.com/loganravin4"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-poke-black hover:bg-poke-black/80 transition-colors px-6 py-3 rounded-lg font-bold text-white flex items-center gap-2"
          data-track-external="github"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        
        <a
          href="https://www.linkedin.com/in/logan-ravinuthala/"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-poke-blue hover:bg-poke-blue/80 transition-colors px-6 py-3 rounded-lg font-bold text-white flex items-center gap-2"
          data-track-external="linkedin"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </section>

    <!-- New Grad Timeline -->
    <section id="new-grad" class="mb-20 bg-poke-black/35 rounded-2xl p-6 md:p-8 border-2 border-poke-yellow/40" data-section="new-grad">
      <h2 class="font-pokemon text-2xl text-poke-yellow mb-4">
        NEW GRAD TIMELINE
      </h2>
      <p class="text-white/95 text-lg leading-relaxed">
        I graduate in
        <span data-graduation-countdown class="font-bold text-poke-yellow">loading...</span>
        (<span data-graduation-days class="font-bold text-poke-yellow">--</span> days total).
        I am actively exploring New Grad software engineering opportunities for when I graduate.
      </p>
    </section>
  </main>
</BaseLayout>

<script>
  const graduationDate = new Date('2027-05-02T00:00:00-04:00');

  const countdownEls = document.querySelectorAll<HTMLSpanElement>('[data-graduation-countdown]');
  const daysEls = document.querySelectorAll<HTMLSpanElement>('[data-graduation-days]');

  const toWholeDays = (milliseconds: number) => Math.ceil(milliseconds / (1000 * 60 * 60 * 24));

  const formatCountdown = (milliseconds: number) => {
    const totalDays = toWholeDays(milliseconds);
    const totalMonths = Math.floor(totalDays / 30.44);
    const remainingDays = Math.max(0, Math.round(totalDays - totalMonths * 30.44));

    if (totalMonths <= 0) {
      return `${totalDays} day${totalDays === 1 ? '' : 's'}`;
    }

    return `${totalMonths} month${totalMonths === 1 ? '' : 's'} and ${remainingDays} day${remainingDays === 1 ? '' : 's'}`;
  };

  const updateGraduationCountdown = () => {
    if (countdownEls.length === 0 || daysEls.length === 0) return;

    const now = new Date();
    const diff = graduationDate.getTime() - now.getTime();

    if (diff <= 0) {
      countdownEls.forEach((el) => {
        el.textContent = 'graduated!';
      });
      daysEls.forEach((el) => {
        el.textContent = '0';
      });
      return;
    }

    const days = String(toWholeDays(diff));
    const countdown = formatCountdown(diff);
    countdownEls.forEach((el) => {
      el.textContent = countdown;
    });
    daysEls.forEach((el) => {
      el.textContent = days;
    });
  };

  updateGraduationCountdown();
  setInterval(updateGraduationCountdown, 60_000);
</script>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
</style>